import { Button, LineEdit, TextEdit, ScrollView, ComboBox, CheckBox, SpinBox, Palette } from "std-widgets.slint";
import { Palette2 } from "palette.slint";
import { IconButton, Icon, Panel, SegmentedControl, RouteChip } from "components.slint";
import { AppView, IconRail } from "nav.slint";

export struct ProfileRow {
    id: int,
    name: string,
    endpoint: string,
    group: string,
    latency: int,  // -1 = untested, -2 = unreachable, >=0 = ms
    protocol-badge: string,
}

// Flat mirror of guderray_core::OutboundDraft, shaped for one form with protocol-gated
// field groups (see crates/guderray-core/src/draft.rs for the two-way mapping + why a
// flat struct instead of a tagged enum).
export struct NodeDraft {
    protocol: string,
    server: string,
    port: int,
    uuid: string,
    password: string,
    flow: string,
    packet-encoding: string,
    alter-id: int,
    security: string,
    method: string,
    obfs: string,
    obfs-password: string,
    congestion-control: string,
    username: string,
    tls-enabled: bool,
    sni: string,
    insecure: bool,
    alpn: string,
    fingerprint: string,
    reality-public-key: string,
    reality-short-id: string,
    transport-type: string,
    ws-path: string,
    ws-host: string,
    grpc-service-name: string,
    http-host: string,
    http-path: string,
    httpupgrade-path: string,
    httpupgrade-host: string,
}

export struct SubRow {
    name: string,
    url: string,
}

export struct ConnDisplayRow {
    host: string,
    destination: string,
    down-text: string,
    up-text: string,
}

export struct ConnectionRow {
    id: string,
    host: string,
    destination: string,
    route: string,  // "direct" | "proxy" | "block"
    duration: string,
    down-text: string,
    up-text: string,
}

component ToggleSwitch inherits Rectangle {
    in property <string> label;
    in property <string> sub-label: "";
    in-out property <bool> checked: false;
    callback toggled(bool);

    height: sub-label == "" ? 40px : 50px;

    HorizontalLayout {
        padding-left: 2px;
        padding-right: 2px;
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            Text { text: root.label; color: Palette2.text-main; font-size: 13px; }
            if root.sub-label != "": Text { text: root.sub-label; color: Palette2.text-dim; font-size: 11px; }
        }
        Rectangle { horizontal-stretch: 1; }
        // switch track
        Rectangle {
            width: 42px;
            height: 24px;
            border-radius: 12px;
            background: root.checked ? Palette2.accent : Palette2.toggle-off;
            animate background { duration: 130ms; easing: ease-in-out; }
            y: (parent.height - self.height) / 2;
            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 9px;
                background: white;
                y: 3px;
                x: root.checked ? parent.width - self.width - 3px : 3px;
                animate x { duration: 130ms; easing: ease-in-out; }
            }
            ta := TouchArea {
                clicked => {
                    root.checked = !root.checked;
                    root.toggled(root.checked);
                }
            }
        }
    }
}

// Labeled text input used throughout the node editor modal (Phase 4) — one component
// instead of repeating "Text{label} + LineEdit{value}" ~20 times in the form below.
component FormField inherits VerticalLayout {
    in property <string> label;
    in-out property <string> value;
    in property <string> placeholder: "";
    spacing: 3px;
    Text { text: root.label; font-size: 11px; color: Palette2.text-dim; }
    LineEdit { text <=> root.value; placeholder-text: root.placeholder; }
}

// Chip-based rule bucket editor (Phase 6) — replaces the old free-text RuleBox
// textarea. Storage underneath is unchanged (still the newline-joined RuleList text
// via to_lines()/from_lines()); this is purely a UI-layer upgrade, each chip is one
// line, add/remove take effect immediately (no separate Save step).
component RuleChipEditor inherits VerticalLayout {
    in property <string> label;
    in property <color> label-color;
    in property <[string]> entries;
    in property <string> add-placeholder: "";
    callback add-entry(string);
    callback remove-entry(string);

    spacing: 6px;
    Text { text: root.label; font-size: 12px; font-weight: 600; color: root.label-color; }
    Rectangle {
        height: 160px;
        background: Palette2.page-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette2.card-border;
        clip: true;
        ScrollView {
            VerticalLayout {
                padding: 8px;
                spacing: 6px;
                alignment: start;
                if root.entries.length == 0: Text { text: "—"; font-size: 11px; color: Palette2.text-dim; }
                for e in root.entries: HorizontalLayout {
                    Rectangle {
                        border-radius: 4px;
                        background: Palette2.row-hover;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            padding-top: 3px;
                            padding-bottom: 3px;
                            spacing: 6px;
                            Text {
                                text: e;
                                font-size: 11px;
                                font-family: "Consolas";
                                color: Palette2.text-main;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                            Rectangle {
                                width: 14px;
                                height: 14px;
                                y: (parent.height - self.height) / 2;
                                Text {
                                    text: "×";
                                    font-size: 13px;
                                    color: Palette2.text-dim;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { clicked => { root.remove-entry(e); } }
                            }
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }
        }
    }
    LineEdit {
        placeholder-text: root.add-placeholder;
        accepted(text) => {
            if (text != "") {
                root.add-entry(text);
                self.text = "";
            }
        }
    }
}

